{
  "name": "store-nvim-telemetry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute store-nvim-telemetry --local --file=schema.sql",
