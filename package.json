  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "wrangler": "^4.71.0"
  }
